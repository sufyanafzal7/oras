# ============================================================
# ORAS — root .gitignore
# Git is initialized at the oras/ folder root.
# ============================================================

# ---------- Python / ML (oras/ml) ----------
ml/venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Datasets are tens of GB and not source code — never commit these.
# Document how to re-download/regenerate them instead.
ml/datasets/

# Training run outputs (weights, logs, plots) — large, regenerable.
ml/runs/
ml/venv/

# ---------- Backend (oras/backend) ----------
backend/uploads/
backend/venv/
backend/__pycache__/
backend/instance/
backend/.env
*.db
*.sqlite3

# ---------- Flutter (oras/app) ----------
# app/.gitignore already covers most of this (auto-generated by
# `flutter create`) — duplicated here too in case git runs from root.
app/build/
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/.pub-cache/
app/.pub/
app/**/ephemeral/

# ---------- IDE / editor ----------
.vscode/
.idea/
*.iml

# ---------- OS junk ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Secrets — never commit these ----------
*.pem
*.key
.env
**/google-services.json
**/GoogleService-Info.plist


ml/models/
models/

# Flutter / Android build reports
app/android/build/

# ML outputs
ml/outputs/

# Large documentation artifacts (if regenerated)
folder_structure.txt